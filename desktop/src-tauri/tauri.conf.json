{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claw Quest",
  "version": "0.1.0",
  "identifier": "ai.clawquest.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Claw Quest",
        "width": 1580,
        "height": 1120,
        "minWidth": 1580,
        "minHeight": 1120,
        "maxWidth": 1580,
        "maxHeight": 1120,
        "center": true,
        "decorations": false,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
